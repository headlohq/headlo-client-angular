{
  "compilerOptions": {
    "target":                     "ES2022",
    "lib":                        ["ES2022", "dom"],
    "module":                     "ES2022",
    "moduleResolution":           "bundler",
    "experimentalDecorators":     true,
    "strict":                     true,
    "skipLibCheck":                true,
    "sourceMap":                  true,
    "declaration":                false,
    "useDefineForClassFields":    false
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  },
  "include": ["src"]
}
